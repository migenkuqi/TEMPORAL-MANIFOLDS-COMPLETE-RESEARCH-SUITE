def main():
    """Run the complete temporal manifold experiment suite."""
    
    start_time = time.time()
    
    # Run all experiments
    all_results = run_all_experiments(config)
    
    # Create master visualization
    create_master_plot(all_results, config)
    
    # Save all results to JSON
    json_results = {}
    for k, v in all_results.items():
        if k == 'opposing' and 'model' in v:
            # Can't save model to JSON
            json_results[k] = {k2: v2 for k2, v2 in v.items() if k2 != 'model'}
        elif k in ['split', 'overlapping', 'progressive', 'multidomain']:
            # Convert tensor keys to strings
            results_dict = {}
            for t_key, t_val in v['results'].items():
                results_dict[str(t_key)] = t_val if isinstance(t_val, list) else t_val.tolist()
            json_results[k] = {
                'results': results_dict,
                'task_names': v.get('task_names', [])
            }
        elif k == 'cifar':
            json_results[k] = {
                'final_acc': v['final_acc'],
                'history': {k2: v2 for k2, v2 in v['history'].items()}
            }
        elif k == 'scaling':
            json_results[k] = v
        elif k == 'ablation':
            json_results[k] = v
    
    with open(f"{config.output_dir}/all_results.json", 'w') as f:
        json.dump(json_results, f, indent=2)
    
    # Print final verdict
    print_final_verdict(all_results, config)
    
    elapsed = time.time() - start_time
    print(f"\nTotal time: {elapsed/60:.1f} minutes")
    
    return all_results

if __name__ == "__main__":
    results = main()
