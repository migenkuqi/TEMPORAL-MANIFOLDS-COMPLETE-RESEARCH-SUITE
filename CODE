class AlphaNet(nn.Module):
    """Alpha(t) conditioner with learnable basis functions."""
    
    def __init__(self, num_bases: int, hidden: int = 64):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(1, hidden), nn.GELU(),
            nn.Linear(hidden, hidden), nn.GELU(),
            nn.Linear(hidden, hidden), nn.GELU(),
            nn.Linear(hidden, num_bases)
        )
        # Small init for smooth start
        for m in self.net.modules():
            if isinstance(m, nn.Linear):
                nn.init.xavier_uniform_(m.weight, gain=0.05)
    
    def forward(self, t: torch.Tensor) -> torch.Tensor:
        if t.dim() == 1:
            t = t.unsqueeze(1)
        return torch.tanh(self.net(t))  # Bound to [-1, 1]


class TemporalLowRankLinear(nn.Module):
    """
    W(t) = W0 + (1/rank) * Σ α_i(t) * U_i V_i^T
    """
    
    def __init__(self, in_f: int, out_f: int, rank: int, num_bases: int):
        super().__init__()
        self.in_f = in_f
        self.out_f = out_f
        self.rank = rank
        self.num_bases = num_bases
        self.scale = 1.0 / rank
        
        # Base weight
        self.W0 = nn.Parameter(torch.randn(out_f, in_f) * 0.015)
        
        # Low-rank trajectory bases
        self.U = nn.Parameter(torch.randn(num_bases, out_f, rank) * 0.015)
        self.V = nn.Parameter(torch.randn(num_bases, in_f, rank) * 0.015)
        
        # Alpha conditioner
        self.alpha_net = AlphaNet(num_bases)
        
        # For analysis
        self.alpha_history = []
    
    def forward(self, x: torch.Tensor, t: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
        batch = x.shape[0]
        
        # Get trajectory coefficients
        alpha = self.alpha_net(t)  # (B, K)
        
        # Store for analysis
        if len(self.alpha_history) < 1000:
            self.alpha_history.append(alpha[0:1].detach().cpu())
        
        # Compute U_i V_i^T for all bases
        bases = torch.einsum("kor,kir->koi", self.U, self.V)  # K×O×I
        deltaW = torch.einsum("bk,koi->boi", alpha, bases)   # B×O×I
        
        # Apply scaling and add to base
        W_eff = self.W0.unsqueeze(0) + self.scale * deltaW   # B×O×I
        
        # Apply linear transformation
        out = torch.bmm(W_eff, x.unsqueeze(-1)).squeeze(-1)   # B×O
        
        return out, alpha
    
    def get_weight_at_time(self, t: float) -> torch.Tensor:
        """Get weight matrix at specific time."""
        with torch.no_grad():
            t_tensor = torch.tensor([t], device=self.W0.device)
            alpha = self.alpha_net(t_tensor)[0]
            
            W = self.W0.clone()
            for i in range(self.num_bases):
                direction = self.U[i] @ self.V[i].T
                W = W + self.scale * alpha[i] * direction
            
            return W


class TemporalNet(nn.Module):
    """Flexible temporal network for all experiments."""
    
    def __init__(self, input_dim: int, hidden_dim: int, output_dim: int,
                 rank: int, num_bases: int, num_layers: int = 3):
        super().__init__()
        
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.output_dim = output_dim
        self.num_layers = num_layers
        
        # Build temporal layers
        self.layers = nn.ModuleList()
        
        # Input layer
        self.layers.append(TemporalLowRankLinear(input_dim, hidden_dim, rank, num_bases))
        
        # Hidden layers
        for _ in range(num_layers - 2):
            self.layers.append(TemporalLowRankLinear(hidden_dim, hidden_dim, rank, num_bases))
        
        # Output layer
        self.layers.append(TemporalLowRankLinear(hidden_dim, output_dim, rank, num_bases))
        
        self.dropout = nn.Dropout(0.15)
        
        # For storing all alphas
        self.all_alphas = []
    
    def forward(self, x: torch.Tensor, t: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
        x = x.view(x.size(0), -1)
        alphas_list = []
        
        for i, layer in enumerate(self.layers):
            x, alpha = layer(x, t)
            alphas_list.append(alpha)
            if i < len(self.layers) - 1:  # No activation on output
                x = F.relu(x)
                x = self.dropout(x)
        
        # Concatenate all alphas
        alphas = torch.cat(alphas_list, dim=1)
        self.all_alphas = alphas_list
        
        return x, alphas


class TemporalCNN(nn.Module):
    """Temporal network for CIFAR-10 with CNN frontend."""
    
    def __init__(self, rank: int = 24, num_bases: int = 12):
        super().__init__()
        
        # CNN feature extractor
        self.conv_layers = nn.Sequential(
            nn.Conv2d(3, 32, 3, padding=1),
            nn.BatchNorm2d(32),
            nn.ReLU(),
            nn.MaxPool2d(2),
            
            nn.Conv2d(32, 64, 3, padding=1),
            nn.BatchNorm2d(64),
            nn.ReLU(),
            nn.MaxPool2d(2),
            
            nn.Conv2d(64, 128, 3, padding=1),
            nn.BatchNorm2d(128),
            nn.ReLU(),
            nn.MaxPool2d(2),
        )
        
        # Temporal layers
        self.temporal_fc1 = TemporalLowRankLinear(128 * 4 * 4, 256, rank, num_bases)
        self.temporal_fc2 = TemporalLowRankLinear(256, 128, rank, num_bases)
        self.temporal_fc3 = TemporalLowRankLinear(128, 10, rank, num_bases)
        
        self.dropout = nn.Dropout(0.2)
    
    def forward(self, x: torch.Tensor, t: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
        # CNN features
        x = self.conv_layers(x)
        x = x.view(x.size(0), -1)
        
        # Temporal layers
        x, a1 = self.temporal_fc1(x, t)
        x = F.relu(x)
        x = self.dropout(x)
        
        x, a2 = self.temporal_fc2(x, t)
        x = F.relu(x)
        x = self.dropout(x)
        
        x, a3 = self.temporal_fc3(x, t)
        
        alphas = torch.cat([a1, a2, a3], dim=1)
        
        return x, alphas

#===============================================================================
# LOSS FUNCTIONS
#===============================================================================

def diversity_loss(alphas: torch.Tensor) -> torch.Tensor:
    """Encourage alpha diversity across batch."""
    return -torch.var(alphas, dim=0).mean()

def smoothness_loss(alphas: torch.Tensor, t: torch.Tensor) -> torch.Tensor:
    """Encourage alpha(t) to vary smoothly with t."""
    if alphas.size(0) <= 1:
        return torch.tensor(0.0, device=alphas.device)
    
    # Sort by t
    t_sorted, idx = torch.sort(t)
    alphas_sorted = alphas[idx]
    
    # Finite differences
    dt = t_sorted[1:] - t_sorted[:-1]
    d_alpha = alphas_sorted[1:] - alphas_sorted[:-1]
    
    return torch.mean((d_alpha / (dt.unsqueeze(1) + 1e-6)) ** 2)

def soft_interpolation_loss(logits: torch.Tensor, t: torch.Tensor,
                           labels_A: torch.Tensor, labels_B: torch.Tensor,
                           temperature: float = 2.0) -> torch.Tensor:
    """Soft labeling for smooth interpolation."""
    probs = torch.sigmoid(logits)
    
    # Blend labels
    blend = (1 - t) * labels_A + t * labels_B
    
    # Add uncertainty at midpoints
    uncertainty = torch.exp(-temperature * (t - 0.5)**2)
    soft_target = (1 - uncertainty) * blend + uncertainty * 0.5
    
    return F.binary_cross_entropy(probs, soft_target)

