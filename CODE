def prepare_split_mnist():
    """Three non-overlapping tasks."""
    transform = transforms.ToTensor()
    
    train_full = datasets.MNIST("./data", train=True, download=True, transform=transform)
    test_full = datasets.MNIST("./data", train=False, transform=transform)
    
    targets_train = train_full.targets.clone()
    targets_test = test_full.targets.clone()
    
    masks_train = [
        (targets_train <= 3),
        (targets_train >= 4) & (targets_train <= 6),
        (targets_train >= 7)
    ]
    masks_test = [
        (targets_test <= 3),
        (targets_test >= 4) & (targets_test <= 6),
        (targets_test >= 7)
    ]
    
    train_datasets = [Subset(train_full, torch.nonzero(m).squeeze()) for m in masks_train]
    test_loaders = [
        DataLoader(Subset(test_full, torch.nonzero(m).squeeze()), batch_size=256, shuffle=False)
        for m in masks_test
    ]
    
    return train_datasets, test_loaders, ["0-3", "4-6", "7-9"], [0.0, 0.5, 1.0]

def prepare_overlapping_mnist():
    """Three tasks with overlap."""
    transform = transforms.ToTensor()
    
    train_full = datasets.MNIST("./data", train=True, download=True, transform=transform)
    test_full = datasets.MNIST("./data", train=False, transform=transform)
    
    targets_train = train_full.targets.clone()
    targets_test = test_full.targets.clone()
    
    masks_train = [
        (targets_train <= 3),
        (targets_train >= 2) & (targets_train <= 5),
        (targets_train >= 5)
    ]
    masks_test = [
        (targets_test <= 3),
        (targets_test >= 2) & (targets_test <= 5),
        (targets_test >= 5)
    ]
    
    train_datasets = [Subset(train_full, torch.nonzero(m).squeeze()) for m in masks_train]
    test_loaders = [
        DataLoader(Subset(test_full, torch.nonzero(m).squeeze()), batch_size=256, shuffle=False)
        for m in masks_test
    ]
    
    return train_datasets, test_loaders, ["0-3", "2-5", "5-9"], [0.0, 0.5, 1.0]

def prepare_opposing_binary():
    """Binary tasks that flip mapping."""
    transform = transforms.ToTensor()
    
    train_full = datasets.MNIST("./data", train=True, download=True, transform=transform)
    test_full = datasets.MNIST("./data", train=False, transform=transform)
    
    class DualLabelDataset(torch.utils.data.Dataset):
        def __init__(self, images, labels_A, labels_B):
            self.images = images
            self.labels_A = labels_A
            self.labels_B = labels_B
        def __len__(self): return len(self.images)
        def __getitem__(self, idx):
            return self.images[idx], self.labels_A[idx], self.labels_B[idx]
    
    # Prepare images
    images_train = train_full.data.float().unsqueeze(1) / 255.0
    images_test = test_full.data.float().unsqueeze(1) / 255.0
    
    targets_train = train_full.targets.clone()
    targets_test = test_full.targets.clone()
    
    # Task A (t=0): 0-3→0, 4-9→1
    # Task B (t=1): 0-3→1, 4-9→0
    train_A = (targets_train >= 4).float()
    train_B = (targets_train < 4).float()
    test_A = (targets_test >= 4).float()
    test_B = (targets_test < 4).float()
    
    train_dataset = DualLabelDataset(images_train, train_A, train_B)
    test_dataset = DualLabelDataset(images_test, test_A, test_B)
    
    train_loader = DataLoader(train_dataset, batch_size=config.batch_size, shuffle=True)
    test_loader = DataLoader(test_dataset, batch_size=256)
    
    return train_loader, test_loader, ["Task A", "Task B"]

def prepare_progressive_mnist():
    """Tasks that progressively add digits."""
    transform = transforms.ToTensor()
    
    train_full = datasets.MNIST("./data", train=True, download=True, transform=transform)
    test_full = datasets.MNIST("./data", train=False, transform=transform)
    
    targets_train = train_full.targets.clone()
    targets_test = test_full.targets.clone()
    
    # Progressive tasks: each adds more digits
    thresholds = [2, 4, 6, 8, 9]  # digits 0-2, 0-4, 0-6, 0-8, 0-9
    masks_train = [(targets_train <= t) for t in thresholds]
    masks_test = [(targets_test <= t) for t in thresholds]
    
    train_datasets = [Subset(train_full, torch.nonzero(m).squeeze()) for m in masks_train]
    test_loaders = [
        DataLoader(Subset(test_full, torch.nonzero(m).squeeze()), batch_size=256, shuffle=False)
        for m in masks_test
    ]
    
    task_names = [f"0-{t}" for t in thresholds]
    task_anchors = [0.0, 0.25, 0.5, 0.75, 1.0]
    
    return train_datasets, test_loaders, task_names, task_anchors

def prepare_multidomain():
    """MNIST + FashionMNIST as two domains."""
    transform = transforms.ToTensor()
    
    mnist_train = datasets.MNIST("./data", train=True, download=True, transform=transform)
    mnist_test = datasets.MNIST("./data", train=False, transform=transform)
    
    fashion_train = datasets.FashionMNIST("./data", train=True, download=True, transform=transform)
    fashion_test = datasets.FashionMNIST("./data", train=False, transform=transform)
    
    # Create datasets with domain labels
    class DomainDataset(torch.utils.data.Dataset):
        def __init__(self, mnist_data, fashion_data):
            self.mnist_data = [(img, 0, label) for img, label in mnist_data]  # domain 0
            self.fashion_data = [(img, 1, label) for img, label in fashion_data]  # domain 1
            self.all_data = self.mnist_data + self.fashion_data
        
        def __len__(self):
            return len(self.all_data)
        
        def __getitem__(self, idx):
            img, domain, label = self.all_data[idx]
            return img, domain, label
    
    train_dataset = DomainDataset(list(mnist_train), list(fashion_train))
    test_dataset = DomainDataset(list(mnist_test), list(fashion_test))
    
    train_loader = DataLoader(train_dataset, batch_size=config.batch_size, shuffle=True)
    test_loader = DataLoader(test_dataset, batch_size=256)
    
    return train_loader, test_loader, ["MNIST", "FashionMNIST"]

def prepare_cifar10():
