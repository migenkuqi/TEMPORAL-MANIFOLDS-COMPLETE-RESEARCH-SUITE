        print("-"*80)
        
        train_datasets, test_loaders, task_names, anchors = prepare_overlapping_mnist()
        model = TemporalNet(784, config.base_hidden, 10,
                           config.base_rank, config.base_bases).to(device)
        
        results = train_multitask(model, train_datasets, test_loaders, anchors,
                                  config, "Overlapping MNIST")
        results['task_names'] = task_names
        all_results['overlapping'] = results
        
        if config.save_models:
            torch.save(model.state_dict(), f"{config.output_dir}/overlapping_mnist.pt")
    
    # Experiment 3: Opposing Binary
    if config.run_opposing:
        print("\n" + "-"*80)
        print("EXPERIMENT 3: Opposing Binary Tasks")
        print("-"*80)
        
        train_loader, test_loader, task_names = prepare_opposing_binary()
        model = TemporalNet(784, config.base_hidden, 1,
                           config.base_rank, config.base_bases).to(device)
        
        results = train_opposing(model, train_loader, test_loader, config)
        results['model'] = model  # Store for later analysis
        all_results['opposing'] = results
        
        if config.save_models:
            torch.save(model.state_dict(), f"{config.output_dir}/opposing.pt")
    
    # Experiment 4: Progressive Tasks
    if config.run_progressive:
        print("\n" + "-"*80)
        print("EXPERIMENT 4: Progressive Tasks (Continual Learning)")
        print("-"*80)
        
        train_datasets, test_loaders, task_names, anchors = prepare_progressive_mnist()
        model = TemporalNet(784, config.base_hidden, 10,
                           config.base_rank, config.base_bases).to(device)
        
        results = train_multitask(model, train_datasets, test_loaders, anchors,
                                  config, "Progressive")
        results['task_names'] = task_names
        all_results['progressive'] = results
        
        if config.save_models:
            torch.save(model.state_dict(), f"{config.output_dir}/progressive.pt")
    
    # Experiment 5: Multi-Domain
    if config.run_multidomain:
        print("\n" + "-"*80)
        print("EXPERIMENT 5: Multi-Domain (MNIST + FashionMNIST)")
        print("-"*80)
        
        train_loader, test_loader, task_names = prepare_multidomain()
        
        # Special handling for domain classification
        class DomainNet(nn.Module):
            def __init__(self):
                super().__init__()
                self.temporal = TemporalNet(784, config.base_hidden, 10,
                                           config.base_rank, config.base_bases)
                self.domain_head = nn.Linear(10, 2)  # Predict domain from features
            
            def forward(self, x, t):
                features, alphas = self.temporal(x, t)
                domain_logits = self.domain_head(features)
                return domain_logits, alphas
        
        model = DomainNet().to(device)
        
        # Custom training loop for domain classification
        optimizer = torch.optim.AdamW(model.parameters(), lr=config.base_lr)
        
        for epoch in range(config.base_epochs):
            model.train()
            for data, domain, _ in train_loader:
                data, domain = data.to(device), domain.to(device)
                t = torch.rand(data.size(0), device=device)
                
                logits, alphas = model(data, t)
                loss = F.cross_entropy(logits, domain)
                
                optimizer.zero_grad()
                loss.backward()
                optimizer.step()
        
        # Evaluate
        t_vals = np.linspace(0, 1, 21)
        domain_accs = {t: [] for t in t_vals}
        
        model.eval()
        with torch.no_grad():
            for t in t_vals:
                t_tensor = torch.full((256,), t, device=device)
                correct = total = 0
                for data, domain, _ in test_loader:
                    data, domain = data.to(device), domain.to(device)
                    t_batch = t_tensor[:data.size(0)]
                    
                    logits, _ = model(data, t_batch)
                    pred = logits.argmax(dim=1)
                    correct += (pred == domain).sum().item()
                    total += data.size(0)
                
                domain_accs[t] = correct / total
        
        all_results['multidomain'] = {
            'results': {float(k): [v] for k, v in domain_accs.items()},
            'task_names': task_names
        }
    
    # Experiment 6: CIFAR-10
    if config.run_cifar:
        print("\n" + "-"*80)
        print("EXPERIMENT 6: CIFAR-10")
        print("-"*80)
        
        train_loader, test_loader = prepare_cifar10()
        model = TemporalCNN(rank=config.base_rank, num_bases=config.base_bases).to(device)
        
        results = train_cifar(model, train_loader, test_loader, config)
        all_results['cifar'] = results
        
        if config.save_models:
            torch.save(model.state_dict(), f"{config.output_dir}/cifar.pt")
    
    # Experiment 7: Scaling Laws
    if config.run_scaling:
        print("\n" + "-"*80)
        print("EXPERIMENT 7: Scaling Laws")
        print("-"*80)
        
        scaling_results = run_scaling_experiment(config)
        all_results['scaling'] = scaling_results
    
    # Experiment 8: Ablation Study
    if config.run_ablation:
        print("\n" + "-"*80)
        print("EXPERIMENT 8: Ablation Study")
        print("-"*80)
        
        ablation_results = run_ablation_study(config)
        all_results['ablation'] = ablation_results
    
    return all_results

