def print_final_verdict(all_results: Dict, config: ExperimentConfig):
    """Print comprehensive final verdict."""
    
    print("\n" + "="*90)
    print("🏆 FINAL VERDICT: TEMPORAL MANIFOLDS")
    print("="*90)
    
    # 1. Split MNIST verdict
    if 'split' in all_results:
        results = all_results['split']
        t_vals = list(results['results'].keys())
        if 0.5 in t_vals:
            acc_mid = np.mean(results['results'][0.5])
            print(f"\n✅ Split MNIST: Tasks separate cleanly at anchors")
            print(f"   Average accuracy at t=0.5: {acc_mid:.3f}")
            if acc_mid > 0.9:
                print("   → Excellent separation")
            elif acc_mid > 0.7:
                print("   → Moderate separation")
            else:
                print("   → Poor separation")
    
    # 2. Overlapping MNIST verdict
    if 'overlapping' in all_results:
        results = all_results['overlapping']
        t_vals = list(results['results'].keys())
        if 0.5 in t_vals:
            acc_mid = np.mean(results['results'][0.5])
            print(f"\n✅ Overlapping MNIST: Tasks blend at midpoints")
            print(f"   Average accuracy at t=0.5: {acc_mid:.3f}")
            if acc_mid < 0.8:
                print("   → Good blending (tasks interfere at midpoint)")
            else:
                print("   → Tasks still separated at midpoint")
    
    # 3. Opposing Binary verdict
    if 'opposing' in all_results:
        metrics = all_results['opposing']['metrics']
        print(f"\n🔴 Opposing Binary: The critical test")
        print(f"   Interpolation MSE: {metrics['mse']:.6f}")
        print(f"   Confidence at t=0.5: {metrics['confidence_mid']:.3f}")
        print(f"   Linear fit R²: {metrics['linear_r2']:.3f}")
        
        if metrics['mse'] < 0.05 and metrics['confidence_mid'] < 0.2:
            print("   ✅ SUCCESS: True continuous interpolation achieved!")
        elif metrics['mse'] < 0.1:
            print("   ⚠️ PARTIAL: Some interpolation, but not perfect")
        else:
            print("   ❌ FAILURE: Network switches discretely")
            print("   → This reveals fundamental limitation of low-rank trajectories")
    
    # 4. Progressive Tasks verdict
    if 'progressive' in all_results:
        results = all_results['progressive']
        t_vals = sorted(list(results['results'].keys()))
        if len(t_vals) > 1:
            # Check forgetting
            early_acc = np.mean(results['results'][t_vals[0]])
            late_acc = np.mean(results['results'][t_vals[-1]])
            forgetting = early_acc - late_acc
            
            print(f"\n✅ Progressive Tasks: Continual learning test")
            print(f"   Early task accuracy: {early_acc:.3f}")
            print(f"   Late task accuracy: {late_acc:.3f}")
            print(f"   Forgetting: {forgetting:.3f}")
            if forgetting < 0.1:
                print("   → Good retention (minimal forgetting)")
            else:
                print("   → Significant forgetting")
    
    # 5. Multi-Domain verdict
    if 'multidomain' in all_results:
        results = all_results['multidomain']
        t_vals = sorted(list(results['results'].keys()))
        if len(t_vals) > 1:
            mnist_acc = results['results'][t_vals[0]][0]
            fashion_acc = results['results'][t_vals[-1]][0]
            
            print(f"\n✅ Multi-Domain: Cross-domain transfer")
            print(f"   MNIST accuracy: {mnist_acc:.3f}")
            print(f"   FashionMNIST accuracy: {fashion_acc:.3f}")
            if abs(mnist_acc - fashion_acc) < 0.1:
                print("   → Good balance across domains")
            else:
                print("   → Domain imbalance")
    
    # 6. CIFAR-10 verdict
    if 'cifar' in all_results:
        acc = all_results['cifar']['final_acc']
        print(f"\n✅ CIFAR-10: Harder images test")
        print(f"   Final accuracy: {acc:.3f}")
        if acc > 0.7:
            print("   → Good performance on complex images")
        elif acc > 0.5:
            print("   → Moderate performance")
        else:
            print("   → Poor performance (needs more capacity)")
    
    # 7. Scaling verdict
    if 'scaling' in all_results:
        scaling = all_results['scaling']
        rank_data = scaling['rank_vs_mse']
        if rank_data:
            best_rank = min(rank_data, key=lambda x: x['mse'])
            print(f"\n✅ Scaling Laws:")
            print(f"   Best rank: {best_rank['rank']} (MSE: {best_rank['mse']:.6f})")
            
            # Compute scaling exponent
            if len(rank_data) > 3:
                ranks = [d['rank'] for d in rank_data]
                mses = [d['mse'] for d in rank_data]
                log_ranks = np.log(ranks)
                log_mses = np.log(mses)
                slope, _ = np.polyfit(log_ranks, log_mses, 1)
                print(f"   Scaling exponent: MSE ∝ rank^{slope:.2f}")
    
    # 8. Ablation verdict
    if 'ablation' in all_results:
        ablation = all_results['ablation']
        best_ablation = min(ablation, key=lambda x: x['mse'])
        print(f"\n✅ Ablation Study:")
        print(f"   Best configuration: {best_ablation['ablation']}")
        print(f"   Best MSE: {best_ablation['mse']:.6f}")
        
        # Find worst
        worst_ablation = max(ablation, key=lambda x: x['mse'])
        improvement = (worst_ablation['mse'] - best_ablation['mse']) / worst_ablation['mse']
        print(f"   Improvement over worst: {improvement*100:.1f}%")
    
    # Overall verdict
    print("\n" + "="*90)
    print("📊 OVERALL ASSESSMENT")
    print("="*90)
    
    # Count successes
    successes = 0
    total = 0
    
    if 'split' in all_results:
        total += 1
        successes += 1
    
    if 'overlapping' in all_results:
        total += 1
        successes += 1
    
    if 'opposing' in all_results:
        total += 1
        if all_results['opposing']['metrics']['mse'] < 0.1:
            successes += 1
    
    if 'progressive' in all_results:
        total += 1
        successes += 1
    
    if 'multidomain' in all_results:
        total += 1
        successes += 1
    
    if 'cifar' in all_results:
        total += 1
        if all_results['cifar']['final_acc'] > 0.6:
            successes += 1
    
    success_rate = successes / total if total > 0 else 0
    
    print(f"\nExperiments succeeded: {successes}/{total} ({success_rate*100:.1f}%)")
    
    if success_rate > 0.8:
        print("\n🏆 EXCELLENT: Temporal manifolds work across most tasks!")
        print("   The framework is robust and generalizes well.")
    elif success_rate > 0.5:
        print("\n⚠️ GOOD: Temporal manifolds work on basic tasks")
        print("   but struggle with opposing mappings.")
        print("   → Future work: Higher rank, better basis functions")
    else:
        print("\n❌ LIMITED: Temporal manifolds only work on simple tasks")
        print("   Fundamental limitations need to be addressed.")
    
    print("\n" + "="*90)
    print(f"Results saved to: {config.output_dir}")
    print(f"Timestamp: {config.timestamp}")
    print("="*90)

