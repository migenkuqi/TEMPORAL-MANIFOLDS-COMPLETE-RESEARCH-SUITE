def run_ablation_study(config: ExperimentConfig) -> Dict:
    """Test importance of each component."""
    
    print("\n" + "="*80)
    print("ABLATION STUDY")
    print("="*80)
    
    train_loader, test_loader, _ = prepare_opposing_binary()
    
    # Store original values
    orig_div = config.diversity_lambda
    orig_smooth = config.smooth_lambda
    orig_lr = config.base_lr
    
    ablations = [
        ("full", config.diversity_lambda, config.smooth_lambda, config.base_lr),
        ("no_diversity", 0.0, config.smooth_lambda, config.base_lr),
        ("no_smooth", config.diversity_lambda, 0.0, config.base_lr),
        ("no_regularization", 0.0, 0.0, config.base_lr),
        ("lr_lower", config.diversity_lambda, config.smooth_lambda, config.base_lr * 0.5),
        ("lr_higher", config.diversity_lambda, config.smooth_lambda, config.base_lr * 2.0),
    ]
    
    results = []
    
    for name, div, smooth, lr in ablations:
        print(f"\n  Testing: {name}")
        
        # Update config temporarily
        config.diversity_lambda = div
        config.smooth_lambda = smooth
        config.base_lr = lr
        
        model = TemporalNet(784, config.base_hidden, 1, 24, 12).to(device)
        exp_results = train_opposing(model, train_loader, test_loader, config)
        
        results.append({
            'ablation': name,
            'mse': exp_results['metrics']['mse'],
            'confidence': exp_results['metrics']['confidence_mid']
        })
    
    # Restore original values
    config.diversity_lambda = orig_div
    config.smooth_lambda = orig_smooth
    config.base_lr = orig_lr
    
    return results

