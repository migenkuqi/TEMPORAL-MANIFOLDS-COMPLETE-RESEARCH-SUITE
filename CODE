@torch.no_grad()
def evaluate_binary(model: nn.Module, loader: DataLoader, t_values: List[float]) -> Dict:
    """Comprehensive binary evaluation."""
    model.eval()
    results = {t: {'probs': [], 'logits': []} for t in t_values}
    
    for images, labels_A, labels_B in loader:
        images = images.to(device)
        
        for t in t_values:
            t_tensor = torch.full((images.size(0),), t, device=device)
            logits, _ = model(images, t_tensor)
            probs = torch.sigmoid(logits)
            
            results[t]['probs'].append(probs.cpu())
            results[t]['logits'].append(logits.cpu())
    
    # Aggregate
    summary = []
    for t in t_values:
        probs = torch.cat(results[t]['probs'])
        summary.append({
            't': t,
            'pct_B': (probs > 0.5).float().mean().item(),
            'avg_prob': probs.mean().item(),
            'confidence': (torch.abs(probs - 0.5) * 2).mean().item(),
            'std': probs.std().item(),
            'n': len(probs)
        })
    
    return summary

@torch.no_grad()
def evaluate_multiclass(model: nn.Module, loaders: List[DataLoader], t_values: List[float]) -> Dict:
    """Multiclass evaluation."""
    model.eval()
    
    results = {t: [] for t in t_values}
    
    for t in t_values:
        t_tensor = torch.full((256,), t, device=device)
        task_accs = []
        
        for loader in loaders:
            correct = total = 0
            for data, target in loader:
                data, target = data.to(device), target.to(device)
                t_batch = t_tensor[:data.size(0)]
                
                logits, _ = model(data, t_batch)
                pred = logits.argmax(dim=1)
                correct += (pred == target).sum().item()
                total += target.size(0)
            
            task_accs.append(correct / total if total > 0 else 0.0)
        
        results[t] = task_accs
    
    return results

@torch.no_grad()
def evaluate_alpha_trajectory(model: nn.Module, t_values: torch.Tensor) -> np.ndarray:
    """Extract alpha trajectories."""
    model.eval()
    alphas = []
    
    dummy = torch.zeros(1, model.input_dim).to(device)
    
    for t in t_values:
        t_tensor = t.reshape(1).to(device)
        _, alpha_stack = model(dummy, t_tensor)
        alphas.append(alpha_stack.cpu().numpy()[0])
    
    return np.array(alphas)

def compute_interpolation_metrics(summary: List[Dict]) -> Dict:
    """Compute metrics for interpolation quality."""
    t_vals = np.array([s['t'] for s in summary])
    probs = np.array([s['avg_prob'] for s in summary])
    conf = np.array([s['confidence'] for s in summary])
    
    # MSE from ideal linear interpolation
    mse = np.mean((probs - t_vals) ** 2)
    
    # Confidence dip at t=0.5
    t05_idx = np.argmin(np.abs(t_vals - 0.5))
    conf_mid = conf[t05_idx]
    conf_ends = (conf[0] + conf[-1]) / 2
    dip_ratio = conf_mid / (conf_ends + 1e-6)
    
    # Linearity test
    from scipy import stats
    slope, intercept, r_value, p_value, std_err = stats.linregress(t_vals, probs)
    
    return {
        'mse': float(mse),
        'confidence_mid': float(conf_mid),
        'dip_ratio': float(dip_ratio),
        'linear_r2': float(r_value**2),
        'linear_slope': float(slope),
        'linear_pvalue': float(p_value)
    }

