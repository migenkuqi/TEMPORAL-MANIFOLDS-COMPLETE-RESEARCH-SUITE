def train_opposing(model: nn.Module, train_loader: DataLoader, 
                   test_loader: DataLoader, config: ExperimentConfig) -> Dict:
    """Train on opposing binary tasks."""
    
    optimizer = torch.optim.AdamW(model.parameters(), lr=config.base_lr, 
                                   weight_decay=config.weight_decay)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=config.base_epochs)
    
    history = defaultdict(list)
    best_mse = float('inf')
    
    print("\n  Training opposing binary tasks...")
    
    for epoch in range(1, config.base_epochs + 1):
        model.train()
        total_loss = 0.0
        num_batches = 0
        
        # Progressive regularization
        div_weight = config.diversity_lambda * min(1.0, epoch / config.diversity_warmup)
        smooth_weight = config.smooth_lambda * min(1.0, epoch / config.smooth_warmup)
        
        for images, labels_A, labels_B in train_loader:
            images = images.to(device)
            labels_A = labels_A.to(device)
            labels_B = labels_B.to(device)
            
            # Curriculum sampling
            if epoch < config.base_epochs // 3:
                t = (torch.rand(images.size(0), device=device) > 0.5).float()
            else:
                t = torch.rand(images.size(0), device=device)
            
            # Forward
            logits, alphas = model(images, t)
            
            # Loss
            ce_loss = soft_interpolation_loss(logits.squeeze(), t, labels_A, labels_B)
            reg_loss = (div_weight * diversity_loss(alphas) + 
                       smooth_weight * smoothness_loss(alphas, t))
            loss = ce_loss + reg_loss
            
            optimizer.zero_grad()
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            
            total_loss += loss.item()
            num_batches += 1
        
        scheduler.step()
        
        # Evaluate every 5 epochs
        if epoch % 5 == 0 or epoch == config.base_epochs:
            t_vals = [0.0, 0.25, 0.5, 0.75, 1.0]
            summary = evaluate_binary(model, test_loader, t_vals)
            metrics = compute_interpolation_metrics(summary)
            
            history['loss'].append(total_loss / num_batches)
            history['mse'].append(metrics['mse'])
            history['confidence_mid'].append(metrics['confidence_mid'])
            
            if metrics['mse'] < best_mse:
                best_mse = metrics['mse']
                if config.save_models:
                    torch.save(model.state_dict(), 
                              f"{config.output_dir}/best_opposing.pt")
            
            if config.verbose:
                print(f"    Epoch {epoch:2d} | Loss: {total_loss/num_batches:.4f} | "
                      f"MSE: {metrics['mse']:.6f} | Conf@0.5: {metrics['confidence_mid']:.3f}")
    
    # Final evaluation
    t_vals = np.linspace(0, 1, 21)
    final_summary = evaluate_binary(model, test_loader, t_vals)
    final_metrics = compute_interpolation_metrics(final_summary)
    
    return {
        'summary': final_summary,
        'metrics': final_metrics,
        'history': dict(history)
    }

def train_multitask(model: nn.Module, train_datasets: List, test_loaders: List,
                    task_anchors: List[float], config: ExperimentConfig,
                    experiment_name: str) -> Dict:
    """Train on multi-task setup."""
    
    optimizer = torch.optim.AdamW(model.parameters(), lr=config.base_lr,
                                   weight_decay=config.weight_decay)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=config.base_epochs)
    
    history = defaultdict(list)
    
    print(f"\n  Training {experiment_name}...")
    
    for epoch in range(1, config.base_epochs + 1):
        model.train()
        total_loss = 0.0
        num_batches = 0
        
        div_weight = config.diversity_lambda * min(1.0, epoch / config.diversity_warmup)
        smooth_weight = config.smooth_lambda * min(1.0, epoch / config.smooth_warmup)
        
        for _ in range(500):  # ~60k samples
            task_id = torch.randint(0, len(task_anchors), (1,)).item()
            dataset = train_datasets[task_id]
            anchor = task_anchors[task_id]
            
            loader = DataLoader(dataset, batch_size=config.batch_size, shuffle=True)
            data, target = next(iter(loader))
            data, target = data.to(device), target.to(device)
            
            # Sample t
            if epoch < config.base_epochs // 3:
                t = anchor + config.sigma_narrow * torch.randn(data.size(0), device=device)
            else:
                if torch.rand(1) < 0.7:
                    t = anchor + config.sigma_narrow * torch.randn(data.size(0), device=device)
                else:
                    t = torch.rand(data.size(0), device=device)
            t = t.clamp(0.0, 1.0)
            
            # Forward
            logits, alphas = model(data, t)
            
            # Loss
            ce_loss = F.cross_entropy(logits, target)
            reg_loss = (div_weight * diversity_loss(alphas) + 
                       smooth_weight * smoothness_loss(alphas, t))
            loss = ce_loss + reg_loss
            
            optimizer.zero_grad()
            loss.backward()
            optimizer.step()
            
            total_loss += loss.item()
            num_batches += 1
        
        scheduler.step()
        
        # Evaluate every 5 epochs
        if epoch % 5 == 0 or epoch == config.base_epochs:
            t_vals = [0.0, 0.25, 0.5, 0.75, 1.0]
            results = evaluate_multiclass(model, test_loaders, t_vals)
            
            # Average accuracy at mid
            mid_acc = np.mean(results[0.5])
            history['loss'].append(total_loss / num_batches)
            history['mid_acc'].append(mid_acc)
            
            if config.verbose:
                print(f"    Epoch {epoch:2d} | Loss: {total_loss/num_batches:.4f} | "
                      f"Acc@0.5: {mid_acc:.3f}")
    
    # Final evaluation
    t_vals = np.linspace(0, 1, 21)
    final_results = evaluate_multiclass(model, test_loaders, t_vals)
    
    return {
        'results': final_results,
        'history': dict(history),
        'task_names': [f"Task {i}" for i in range(len(test_loaders))]
    }

def train_cifar(model: nn.Module, train_loader: DataLoader, 
                test_loader: DataLoader, config: ExperimentConfig) -> Dict:
    """Train on CIFAR-10."""
    
    optimizer = torch.optim.AdamW(model.parameters(), lr=config.base_lr * 0.5,
                                   weight_decay=config.weight_decay)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=config.base_epochs)
    
    history = defaultdict(list)
    
    print("\n  Training CIFAR-10...")
    
    for epoch in range(1, config.base_epochs + 1):
        model.train()
        total_loss = 0.0
        num_batches = 0
        
        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            
            # Random t (CIFAR is single task)
            t = torch.rand(data.size(0), device=device)
            
            logits, alphas = model(data, t)
            loss = F.cross_entropy(logits, target)
            
            optimizer.zero_grad()
            loss.backward()
            optimizer.step()
            
            total_loss += loss.item()
            num_batches += 1
        
        scheduler.step()
        
        # Evaluate
        if epoch % 5 == 0 or epoch == config.base_epochs:
            model.eval()
            correct = total = 0
            with torch.no_grad():
                for data, target in test_loader:
                    data, target = data.to(device), target.to(device)
                    t = torch.full((data.size(0),), 0.5, device=device)
                    logits, _ = model(data, t)
                    pred = logits.argmax(dim=1)
                    correct += (pred == target).sum().item()
                    total += target.size(0)
            
            acc = correct / total
            history['loss'].append(total_loss / num_batches)
            history['acc'].append(acc)
            
            if config.verbose:
                print(f"    Epoch {epoch:2d} | Loss: {total_loss/num_batches:.4f} | "
                      f"Acc: {acc:.4f}")
    
    return {
        'final_acc': history['acc'][-1] if history['acc'] else 0,
        'history': dict(history)
    }

